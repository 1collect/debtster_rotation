# HTTP server
ADDR=:8040

# Token for service-to-service access.
# Override this in production with a long random value.
SERVICE_TOKEN=debtster-rotation

# PostgreSQL connection for Sanctum token lookup.
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=root
PG_PASSWORD=hello-world
PG_DB=debtster
PG_SSLMODE=disable

# MongoDB connection for rotation_records.
MONGO_SCHEME=mongodb
MONGO_HOST=127.0.0.1
MONGO_PORT=27017
MONGO_USER=
MONGO_PASSWORD=
MONGO_DB=pkb_imports
MONGO_AUTH_SOURCE=

# MinIO / S3 storage for source and result XLSX files.
AWS_ENDPOINT=127.0.0.1:3304
AWS_USE_SSL=false
AWS_BUCKET=debtster
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1

# Compatibility aliases used by debtster_import .env.
# Leave commented unless this service reads that shared env directly.
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_USERNAME=root
# DB_PASSWORD=hello-world
# DB_DATABASE=debtster
# DB_IMPORT_HOST=127.0.0.1
# DB_IMPORT_PORT=27017
# DB_IMPORT_USERNAME=
# DB_IMPORT_PASSWORD=
# DB_IMPORT_DATABASE=pkb_imports
